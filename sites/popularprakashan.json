{
  "name": "popularprakashan",
  "url": "https://popularprakashan.com/en/shop/page/1/?per_page=1000",
  "engine": "http_html",
  "headers": {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8",
    "Accept-Language": "en-US,en;q=0.9"
  },
  "list": {
    "container": "li.product, .type-product, .product-item, .product-grid-item"
  },
  "next_page": "a.next::attr(href), a[href*='/page/2/']::attr(href), a[href*='/page/']:last-of-type::attr(href), link[rel='next']::attr(href)",
  "key_fields": [
    "url"
  ],
  "fields": {
    "title": {
      "selector": "h2, h3, .woocommerce-loop-product__title, .product-title",
      "type": "string",
      "re": "^(.*?)(?:\\s*[\\-–—].*)?$",
      "regex": "^(.*?)(?:\\s*[\\-–—].*)?$"
    },
    "author": {
      "selector": "h2, h3, .woocommerce-loop-product__title, .product-title",
      "type": "string",
      "re": "[\\-–—]\\s*(.*)$",
      "regex": "[\\-–—]\\s*(.*)$"
    },
    "price": {
      "selector": ".price, .woocommerce-Price-amount",
      "type": "string",
      "re": "(₹\\s*[0-9.,]+)",
      "regex": "(₹\\s*[0-9.,]+)"
    },
    "url": {
      "selector": "a.woocommerce-LoopProduct-link, a[href*='/product/']",
      "attr": "href",
      "type": "url"
    },
    "image_url": {
      "selector": "img",
      "attr": "src",
      "type": "url"
    }
  }
}