{
  "name": "idara",
  "url": "https://idara.com/product-category/islamic_books/urdu_books/?v=c86ee0d9d7ed",
  "engine": "http_html",
  "list": {
    "container": "li.product, .product-grid-item"
  },
  "next_page": "a.next::attr(href)",
  "key_fields": [
    "url"
  ],
  "fields": {
    "title": {
      "selector": "h2, h3, .woocommerce-loop-product__title, .product-title",
      "type": "string"
    },
    "price": {
      "selector": ".price",
      "type": "string"
    },
    "url": {
      "selector": "a.woocommerce-LoopProduct-link, .product-image a",
      "attr": "href",
      "type": "url"
    },
    "image_url": {
      "selector": "img",
      "attr": "src",
      "type": "url"
    }
  }
}