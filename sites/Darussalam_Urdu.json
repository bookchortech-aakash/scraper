    "page_size": 250
  },
  "fields": {
    "id": {
      "path": "id",
      "type": "string"
    },
    "title": {
      "path": "title",
      "type": "string"
    },
    "price": {
      "path": "variants.0.price",
      "type": "string"
    },
    "url": {
      "path": "handle",
      "type": "string"
    },
    "image_url": {
      "path": "images.0.src",
      "type": "string"
    }
  }
}