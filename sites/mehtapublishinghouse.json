{
  "name": "mehtapublishinghouse",
  "url": "https://www.mehtapublishinghouse.com/category/All.aspx",
  "engine": "http_html",
  "list": {
    "container": "table.productlisttablestructure figure, figure.span4.slide"
  },
  "key_fields": [
    "url"
  ],
  "fields": {
    "title": {
      "selector": "span.title a",
      "type": "string"
    },
    "price": {
      "selector": ".price",
      "type": "string",
      "re": "[0-9.,]+",
      "regex": "[0-9.,]+"
    },
    "url": {
      "selector": "a[href*='book-details']",
      "attr": "href",
      "type": "url"
    },
    "image_url": {
      "selector": "img",
      "attr": "src",
      "type": "url"
    }
  }
}