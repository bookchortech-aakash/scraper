{
"name": "rohan_prakashan_full",
"url": "https://rohanprakashan.com/shop/",
"engine": "http_html",
"list": {
"container": "li.product"
},
"next_page": "a.next::attr(href)",
"key_fields": [
"url"
],
"fields": {
"title": {
"selector": "h2, h3, .woocommerce-loop-product__title",
"type": "string"
},
"price": {
"selector": ".price",
"type": "number"
},
"url": {
"selector": "a.woocommerce-LoopProduct-link",
"attr": "href",
"type": "url"
},
"image_url": {
"selector": "img",
"attr": "src",
"type": "url"
}
}
}